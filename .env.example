# grok-install v2.2 environment variables
# Multi-LLM support (Grok + OpenAI + Claude)

TELEGRAM_TOKEN=your_telegram_bot_token_here
GROK_API_KEY=your_grok_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # optional
CLAUDE_API_KEY=your_claude_api_key_here          # optional
X_API_KEY=your_x_api_key_here                    # optional for additional X features
